# ============================================
# ZapCommerce - Variáveis de Ambiente
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ZapCommerce
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://zapcommerce:zapcommerce_dev_2024@localhost:5432/zapcommerce?schema=public"

# Redis
REDIS_URL="redis://:zapcommerce_redis_2024@localhost:6379/0"

# JWT Auth
JWT_SECRET="sua-chave-jwt-super-secreta-mude-em-producao"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="sua-chave-refresh-super-secreta"
JWT_REFRESH_EXPIRES_IN="30d"

# Evolution API (WhatsApp - Provider 1)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=zapcommerce_evo_key_2024

# Meta Cloud API (WhatsApp Oficial - Provider 2)
# Cadastre em: https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=zapcommerce_verify_token_2024
# Token e Phone Number ID são por tenant (configurados no painel)

# ============================================
# Gateway de Pagamento
# ============================================
# O lojista escolhe no painel qual gateway usar.
# Você (dono do SaaS) precisa ter conta em ambos.

# Asaas (Recomendado para começar)
# Cadastre em: https://www.asaas.com
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WALLET_ID=           # Seu walletId (conta principal do SaaS)
ASAAS_WEBHOOK_SECRET=

# Mercado Pago (Marketplace)
# Cadastre em: https://www.mercadopago.com.br/developers
MP_APP_ID=
MP_APP_SECRET=
MP_ACCESS_TOKEN=            # Token da sua conta marketplace
MP_COLLECTOR_ID=            # Seu collector_id (recebe as fees)
MP_REDIRECT_URI=http://localhost:3000/api/payment/mercadopago/callback
MP_WEBHOOK_SECRET=

# MinIO (Storage de imagens)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=zapcommerce
MINIO_SECRET_KEY=zapcommerce_minio_2024
MINIO_BUCKET=zapcommerce
MINIO_USE_SSL=false
NEXT_PUBLIC_STORAGE_URL=http://localhost:9000/zapcommerce

# WebSocket
NEXT_PUBLIC_WS_URL=http://localhost:3000

# SaaS Config
PLATFORM_FEE_DEFAULT=5.0
TRIAL_DAYS=14

# Webhook URLs (configurar no Evolution API e Gateway)
WEBHOOK_BASE_URL=http://localhost:3000/api/webhooks
